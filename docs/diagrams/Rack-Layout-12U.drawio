        <!-- ==================== U1-U2: Cable Management & Patch Panel (TOP) ==================== -->
        <mxCell id="u1-u2" value="U1-U2: Cable Management &amp; Patch Panel&#10;• 24-port Patch Panel (Fiber LC + CAT6 terminations)&#10;• Horizontal Cable Manager (1U)&#10;Function: Central termination point for all incoming/outgoing runs" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1565C0;strokeWidth=1;fontSize=8;" vertex="1" parent="1">
          <mxGeometry x="285" y="100" width="370" height="55" as="geometry" />
        </mxCell>

        <!-- ==================== U3-U4: Core Networking ==================== -->
        <mxCell id="u3-u4" value="U3-U4: Core Networking&#10;• pfSense / OPNsense Firewall Mini-PC (1U or shelf mount, 4-6 port NICs)&#10;  WAN1: Verizon FIOS, WAN2: Starlink (future), LAN: Trunk to Switch&#10;• Main Managed Switch (24-port, e.g. UniFi / MikroTik / Netgear)&#10;Function: Firewall + VLAN segmentation (10 Trusted, 20 IoT, 30 Guest, 40 Work)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BBDEFB;strokeColor=#0D47A1;strokeWidth=1;fontSize=8;" vertex="1" parent="1">
          <mxGeometry x="285" y="160" width="370" height="65" as="geometry" />
        </mxCell>
        <!-- Small indicator for current Cisco (temporary) -->
        <mxCell id="u3-current-note" value="CURRENT (temp on table): Cisco SG100-16" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=7;color=#E65100;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="660" y="175" width="150" height="15" as="geometry" />
        </mxCell>

        <!-- ==================== U5: UPS ==================== -->
        <mxCell id="u5-ups" value="U5: UPS (Rackmount)&#10;• 600-1500VA Rackmount UPS&#10;Function: Battery backup for firewall, switch, Proxmox host, and critical networking. Provides clean power and graceful shutdown." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFECB3;strokeColor=#FF6F00;strokeWidth=1;fontSize=8;" vertex="1" parent="1">
          <mxGeometry x="285" y="230" width="370" height="45" as="geometry" />
        </mxCell>

        <!-- ==================== U6-U8: Compute Host ==================== -->
        <mxCell id="u6-u8" value="U6-U8: Compute Host (Proxmox + Support)&#10;• Proxmox Server (Mini-PC or SFF PC on shelf / 2U tray)&#10;  Primary workloads: Wazuh (XDR + vuln scanning), Home Assistant, Frigate NVR, monitoring, light VMs/LXCs&#10;• Raspberry Pi 3 (small tray or shelf) - temporary / auxiliary tasks&#10;Function: Virtualization host for security, automation, and video recording" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#1B5E20;strokeWidth=1;fontSize=8;" vertex="1" parent="1">
          <mxGeometry x="285" y="280" width="370" height="80" as="geometry" />
        </mxCell>
        <mxCell id="u6-current-note" value="CURRENT (temp): Raspberry Pi 3 (will move to rack or retire)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=7;color=#E65100;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="660" y="320" width="160" height="15" as="geometry" />
        </mxCell>

        <!-- ==================== U9-U10: Expansion / Future ==================== -->
        <mxCell id="u9-u10" value="U9-U10: Expansion / Future&#10;• Currently empty / reserved&#10;Possible future: Additional switch, TrueNAS storage node (if HDDs added), Starlink router integration, or more compute&#10;Function: Growth space for homelab expansion or education track hardware" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#757575;strokeWidth=1;fontSize=8;" vertex="1" parent="1">
          <mxGeometry x="285" y="365" width="370" height="55" as="geometry" />
        </mxCell>

        <!-- ==================== U11-U12: Cable Management + Power (BOTTOM) ==================== -->
        <mxCell id="u11-u12" value="U11-U12: Cable Management + Power&#10;• Vertical Cable Managers (left + right sides of rack)&#10;• PDU (Power Distribution Unit) - switched outlets for all gear&#10;Function: Organized power and cable routing. All cables labeled per standard." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ECEFF1;strokeColor=#37474F;strokeWidth=1;fontSize=8;" vertex="1" parent="1">
          <mxGeometry x="285" y="425" width="370" height="55" as="geometry" />
        </mxCell>

