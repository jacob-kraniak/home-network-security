        <mxCell id="conn_ont_router" edge="1" parent="1" source="ont" target="fr205" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;strokeColor=#6c8ebf;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <!-- Router → Cisco Switch -->
