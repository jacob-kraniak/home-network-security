        <!-- Legend / Notes -->
        <mxCell id="notes" value="&lt;b&gt;Notes:&lt;/b&gt;&lt;br&gt;• Color-coded by function (Compute=green, Network=blue, Power=orange)&lt;br&gt;• Cable management: Color-coded Cat6 by VLAN zone&lt;br&gt;• Power: Dedicated circuits + UPS planned&lt;br&gt;• Cooling: Top-to-bottom airflow + fan tray priority&lt;br&gt;• Future: OPNsense migration, more storage, basement rack expansion" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=12;strokeColor=#666666;fillColor=#f5f5f5;" vertex="1" parent="1">
