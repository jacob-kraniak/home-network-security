        <mxCell id="rack-bottom-label" value="Table / Platform Riser (sturdy basement mounting)" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=8;fontStyle=2;color=#37474F;" vertex="1" parent="1">
          <mxGeometry x="280" y="485" width="380" height="15" as="geometry" />
        </mxCell>

        <!-- ==================== INCOMING CABLES / FLOOR HOLE CALLOUT (TOP) ==================== -->
        <mxCell id="floor-hole-box" value="FLOOR HOLE / RAFTERS (from Upstairs Living Room)&#10;▼ Fiber LC (Verizon FIOS ONT)&#10;▼ Multiple CAT6 runs (house drops)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#B0BEC5;strokeColor=#263238;strokeWidth=2;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="100" y="70" width="170" height="55" as="geometry" />
        </mxCell>

        <!-- Dashed cable path into rack (top) -->
        <mxCell id="cable-path-fiber" value="Fiber + CAT6 bundle (dashed = physical path)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;dashed=1;strokeColor=#455A64;strokeWidth=2;startArrow=classic;startFill=1;" edge="1" parent="1" source="floor-hole-box" target="u1-u2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ==================== LEGEND ==================== -->
        <mxCell id="legend-box" value="Legend" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAFAFA;strokeColor=#616161;strokeWidth=1;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="700" y="80" width="280" height="145" as="geometry" />
        </mxCell>
        <mxCell id="legend-planned" value="PLANNED (Target Final Layout - Layer 2)&#10;• pfSense/OPNsense Mini-PC (blue)&#10;• Managed Switch (24-port)&#10;• Rackmount UPS&#10;• Proxmox Server (SFF/Mini-PC)&#10;• Patch Panel + Managers + PDU" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=8;" vertex="1" parent="1">
          <mxGeometry x="710" y="100" width="260" height="70" as="geometry" />
        </mxCell>
        <mxCell id="legend-current" value="CURRENT / TEMPORARY (Layer 1 - on table/riser now)&#10;• Cisco SG100-16 (will be replaced)&#10;• Raspberry Pi 3 (aux / will migrate)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=8;color=#E65100;" vertex="1" parent="1">
          <mxGeometry x="710" y="170" width="260" height="40" as="geometry" />
        </mxCell>

        <!-- ==================== NOTES SECTION ==================== -->
        <mxCell id="notes-box" value="Notes &amp; Considerations" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF8E1;strokeColor=#FF8F00;strokeWidth=1;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="700" y="240" width="280" height="175" as="geometry" />
        </mxCell>
        <mxCell id="notes-content" value="• Location: Basement, directly under living room floor hole&#10;• Mounting: Sturdy table or 12U platform riser (vibration / access)&#10;• Power: Dedicated circuit recommended; UPS protects core (firewall + switch + Proxmox)&#10;• Ventilation: Ensure good airflow front-to-back in enclosed cabinet&#10;• Cable Labeling Standard:&#10;  - Floor-Hole-Fiber (Verizon)&#10;  - Office-CAT6 (Home Office drop)&#10;  - Upstairs-CAT6 (Living Room devices)&#10;  - Basement-WAP, etc.&#10;• Future: Leave U9-U10 open for storage node or additional gear" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=7;" vertex="1" parent="1">
          <mxGeometry x="710" y="260" width="260" height="150" as="geometry" />
        </mxCell>

        <!-- ==================== LAYERS INDICATOR ==================== -->
        <mxCell id="layers-box" value="Diagram Layers (convert to real draw.io Layers in UI for visibility toggling)&#10;Layer 1: Current Temporary Layout (yellow/orange annotations - items currently loose on table)&#10;Layer 2: Target Final Layout (main blue/gray rack elevation - planned 12U install)&#10;Layer 3: Cable Paths (dashed lines + floor hole callout - physical routing from upstairs)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8EAF6;strokeColor=#3F51B5;strokeWidth=1;fontSize=8;" vertex="1" parent="1">
          <mxGeometry x="100" y="560" width="880" height="55" as="geometry" />
        </mxCell>

        <!-- ==================== ADDITIONAL CALLOUTS & DETAILS ==================== -->
        <mxCell id="cable-detail" value="Cable Management Details:&#10;All runs labeled at both ends. Vertical managers on sides of rack keep front clean. Horizontal managers above/below patch panel." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=7;" vertex="1" parent="1">
          <mxGeometry x="50" y="620" width="220" height="50" as="geometry" />
        </mxCell>

        <mxCell id="power-detail" value="Power: PDU at bottom feeds all devices. UPS only for critical (firewall, switch, Proxmox). Non-critical (future storage) can be on direct PDU." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=7;" vertex="1" parent="1">
          <mxGeometry x="50" y="675" width="220" height="45" as="geometry" />
        </mxCell>

        <!-- Footer -->
        <mxCell id="footer" value="Open in diagrams.net / draw.io • Use the Rack shape library for more realistic 1U/2U/3U shapes • Add real device images/icons • Group elements and use Layers panel for the three layers • Created as starting professional elevation structure 2026-06-04" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=7;color:#757575;" vertex="1" parent="1">
