<mxfile host="app.diagrams.net" modified="2026-06-07" agent="Grok" version="24.0.0" etag="rack-12u-revised-v2-20260607">
  <diagram name="Dual Basement Racks - Physical Layout" id="rack-layout-12u-v2">
    <mxGraphModel dx="1700" dy="1300" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1500" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        
        <!-- Title -->
        <mxCell id="title" value="&lt;b&gt;Dual Basement Racks - Physical Layout (Future State, June 2026)&lt;/b&gt;&lt;br&gt;~12U Enclosed Compute/Storage + ~9U Open Networking | VLAN / Privacy Focused" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=18;fontStyle=1;color=#1565C0;" vertex="1" parent="1">
          <mxGeometry x="180" y="20" width="1100" height="60" as="geometry"/>
        </mxCell>

        <!-- Large Enclosed Rack (~12U) - Compute/Storage -->
        <mxCell id="rack_large" value="Large Enclosed Rack (~12-15U Cabinet)&lt;br&gt;Core Compute / Storage" style="swimlane;startSize=40;horizontal=0;fillColor=#f5f5f5;strokeColor=#666666;html=1;fontStyle=1;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="80" y="100" width="440" height="780" as="geometry"/>
        </mxCell>

        <!-- Units in Large Rack -->
        <!-- U1-2: Dell MiniPC (Sole Container Host) -->
        <mxCell id="minipc" value="Dell MiniPC&lt;br&gt;Sole Containerized Services Host&lt;br&gt;Bazzite / Podman / Wazuh / Proxmox / Jellyfin" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="rack_large">
          <mxGeometry x="50" y="55" width="340" height="90" as="geometry"/>
        </mxCell>

        <!-- U3: Verizon ONT Shelf -->
        <mxCell id="ont" value="Verizon ONT&lt;br&gt;(Moved to Rack)" style="shape=mxgraph.rack.shelf;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="rack_large">
          <mxGeometry x="50" y="160" width="340" height="50" as="geometry"/>
        </mxCell>

        <!-- U4-5: Expansion / Storage -->
        <mxCell id="shelf1" value="1U Shelf - Expansion / Storage" style="shape=mxgraph.rack.shelf;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="rack_large">
          <mxGeometry x="50" y="225" width="340" height="50" as="geometry"/>
        </mxCell>

        <!-- U6-7: Future Expansion -->
        <mxCell id="future_compute" value="Future: Additional Storage / UPS" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;opacity=70;fontSize=11;" vertex="1" parent="rack_large">
          <mxGeometry x="50" y="290" width="340" height="85" as="geometry"/>
        </mxCell>

        <!-- PDU Large -->
        <mxCell id="pdularge" value="PDU / Power Distribution" style="shape=mxgraph.rack.rack_unit;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="rack_large">
          <mxGeometry x="50" y="390" width="340" height="45" as="geometry"/>
        </mxCell>

        <!-- Smaller Open Rack (~9U) - Networking -->
        <mxCell id="rack_small" value="Small Open Rack (~9U)&lt;br&gt;Networking / Edge Devices" style="swimlane;startSize=40;horizontal=0;fillColor=#f8cecc;strokeColor=#b85450;html=1;fontStyle=1;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="600" y="100" width="440" height="620" as="geometry"/>
        </mxCell>

        <!-- Units in Small Rack -->
        <!-- U1: TP-Link FR205 Router (with future Starlink) -->
        <mxCell id="fr205" value="TP-Link FR205 Router&lt;br&gt;Multi-WAN Firewall&lt;br&gt;(Future Starlink WAN Failover)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="rack_small">
          <mxGeometry x="50" y="55" width="340" height="75" as="geometry"/>
        </mxCell>

        <!-- U2: Cisco Unmanaged Switch (Placeholder) -->
        <mxCell id="cisco_switch" value="Cisco Unmanaged Switch&lt;br&gt;(Current Placeholder)&lt;br&gt;Until Managed Switch Acquired" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="rack_small">
          <mxGeometry x="50" y="145" width="340" height="70" as="geometry"/>
        </mxCell>

        <!-- U3: Patch Panel -->
        <mxCell id="patch" value="24-Port Cat6 Patch Panel" style="shape=mxgraph.rack.patch_panel;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="rack_small">
          <mxGeometry x="50" y="230" width="340" height="45" as="geometry"/>
        </mxCell>

        <!-- PDU Small -->
        <mxCell id="pdusmall" value="StarTech 8-Outlet PDU" style="shape=mxgraph.rack.rack_unit;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="rack_small">
          <mxGeometry x="50" y="290" width="340" height="45" as="geometry"/>
        </mxCell>

        <!-- Notes / Legend -->
        <mxCell id="notes" value="&lt;b&gt;Notes:&lt;/b&gt;&lt;br&gt;• Dell MiniPC = Sole container host (Proxmox + services)&lt;br&gt;• TP-Link Archer A7 remains upstairs (as WAP)&lt;br&gt;• Existing Omada WAP stays in office (future rack option)&lt;br&gt;• Cisco switch = temporary until managed replacement&lt;br&gt;• Color-coded cables by VLAN zone&lt;br&gt;• Power: Dedicated circuits + UPS planned&lt;br&gt;• Cooling: Airflow priority" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=12;strokeColor=#666666;fillColor=#f5f5f5;" vertex="1" parent="1">
          <mxGeometry x="80" y="920" width="960" height="160" as="geometry"/>
        </mxCell>

        <!-- Network Connections -->
