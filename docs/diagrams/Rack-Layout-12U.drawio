          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <!-- MiniPC → Cisco Switch -->
        <mxCell id="conn_minipc_switch" edge="1" parent="1" source="minipc" target="cisco_switch" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;strokeColor=#6c8ebf;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <!-- Patch Panel connections (example) -->
        <mxCell id="conn_patch" edge="1" parent="1" source="patch" target="cisco_switch" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;strokeColor=#6c8ebf;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
      </root>
