          <mxGeometry x="340" y="360" width="140" height="70" as="geometry" />
        </mxCell>

        <!-- Main Firewall -->
        <mxCell id="firewall" value="pfSense / OPNsense&#10;Mini-PC (Primary Host)&#10;4+ NICs&#10;&#10;WAN1: FIOS (from ONT)&#10;WAN2: Starlink (future)&#10;LAN: Trunk → Managed Switch&#10;(VLANs 10,20,30,40)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BBDEFB;strokeColor=#1565C0;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="500" y="300" width="160" height="110" as="geometry" />
        </mxCell>

        <!-- Managed Switch -->
