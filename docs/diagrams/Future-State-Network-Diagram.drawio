        </mxCell>

        <!-- Notes Box - Updated -->
        <mxCell id="notes-box" value="Notes&#10;- Centralized Basement Core - Minimal upstairs hardware&#10;- Starlink as WAN2 failover (future)&#10;- Wazuh for asset monitoring + vulnerability scanning&#10;- All IoT strictly isolated (egress-only)&#10;- Layers: 1. Current State (faded) 2. Future Rack Layout 3. Logical VLAN Flow&#10;- Fiber from outside → Basement Rack (FIOS ONT)&#10;- All LAN originates from Managed Switch → Patch Panel → drops&#10;- Archer A7 repurposed as additional WAP (AP Mode)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#FBC02D;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="1280" y="20" width="300" height="160" as="geometry" />
        </mxCell>

        <!-- Upstairs Living Room Layer -->
        <mxCell id="upstairs-layer" value="UPSTAIRS LIVING ROOM (Current Devices - Minimal)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1976D2;fontSize=12;fontStyle=1;opacity=80;" vertex="1" parent="1">
          <mxGeometry x="300" y="80" width="900" height="180" as="geometry" />
        </mxCell>

        <!-- Upstairs Devices - Updated: Ring with note, Archer A7, no old router, no ONT -->
        <mxCell id="upstairs-devices" value="Upstairs Devices (Current)&#10;&#10;• Ring Base Station (Doorbell Cam, Floodlight)&#10;  Kept upstairs for armed status light visibility&#10;• TP-Link Kasa (12x: Switches + Plugs)&#10;• Google Nest (Hub, Thermostat, Minis, Speaker)&#10;• TP-Link Archer A7 (AP Mode) - repurposed as additional WAP&#10;&#10;All wireless via WAPs; wired drops to basement core" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFCDD2;strokeColor=#C62828;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="320" y="100" width="320" height="150" as="geometry" />
        </mxCell>

        <!-- Basement WAP note -->
